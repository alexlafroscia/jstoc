{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../src",

    "rewriteRelativeImportExtensions": true,

    "composite": true,
    "outDir": "../dist",
    "tsBuildInfoFile": "../dist/src.tsbuildinfo",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["../src/**/*.ts"],
  "exclude": ["../src/**/*.test.ts"]
}
