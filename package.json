{
  "name": "jstoc",
  "version": "1.0.0",
  "description": "Generate a Markdown table of contents from your package's exports field",
  "keywords": [
    "jsdoc",
    "readme",
    "table of contents"
  ],
  "license": "ISC",
  "author": "Alex LaFroscia <alex@lafroscia.com>",
  "bin": {
    "jstoc": "./dist/bin.js"
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo",
    "src"
  ],
  "type": "module",
  "exports": {
    "./parser": "./dist/parser.js"
  },
  "dependencies": {
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0"
  }
}
